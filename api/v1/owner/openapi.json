          },
          "400": {
            "description": "Invalid owner redirect info (RVTO2Addr) configuration provided in the request body.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorString"
                },
                "example": "Invalid ownerInfo"
              }
            }
          },
          "404": {
            "description": "Owner redirect info (RVTO2Addr) configuration does not exist. Use POST to create it first.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorString"
                },
                "example": "ownerInfo does not exist"
              }
            }
          },
          "413": {
            "description": "Request payload too large (exceeds maximum allowed size).",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorString"
                },
                "example": "http: request body too large"
              }
            }
          },
          "500": {
            "description": "Internal server error occurred while updating the configuration.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorString"
                },
                "examples": {
                  "readError": {
                    "summary": "Error reading request body",
                    "value": "Error reading body"
                  },
                  "updateError": {
                    "summary": "Error updating in database",
                    "value": "Error updating ownerInfo"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "rvto2addr"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Health": {
        "type": "object",
        "properties": {
          "version": {
            "description": "The server version",
            "type": "string",
            "example": "1.1.0"
          },
          "status": {
            "description": "The server health status",
            "type": "string",
            "example": "OK"
          },
          "message": {
            "description": "Human-readable status message or error description",
            "type": "string",
            "example": "the service is up and running"
          }
        },
        "required": [
          "version",
          "status",
          "message"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "description": "A human-readable error message.",
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "VoucherMetadata": {
        "description": "Ownership voucher metadata (excludes CBOR data)",
        "type": "object",
        "properties": {
          "guid": {
            "description": "Device GUID (hex-encoded)",
            "type": "string",
            "example": "3f4e5d6c7b8a9f0e1d2c3b4a5f6e7d8c"
          },
          "device_info": {
            "description": "Device information string",
            "type": "string",
            "example": "Intel NUC Model XYZ"
          },
          "created_at": {
            "description": "Timestamp when voucher was first inserted",
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:30:00Z"
          },
          "updated_at": {
            "description": "Timestamp when voucher was last updated",
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:30:00Z"
          }
        },
        "required": [
          "guid",
          "device_info",
          "created_at",
          "updated_at"
        ]
      },
      "ErrorString": {
        "description": "A human-readable error message.",
        "type": "string"
      },
      "TransportProtocol": {
        "description": "Transport protocol for TO2 owner server connections\n(FDO specification section 3.3.14, TransportProtocol).\n- `http` - HTTP protocol (code 3)\n- `https` - HTTPS protocol (code 5)\n- `tcp` - Raw TCP connection (code 1)\n- `tls` - TLS-secured TCP connection (code 2)\n- `coap` - CoAP over UDP (code 4)\n- `rest` - RESTful HTTP/HTTPS (mapped to HTTPS)\n",
        "type": "string",
        "example": "https",
        "enum": [
          "rest",
          "http",
          "https",
          "tcp",
          "tls",
          "coap"
        ]
      },
      "DNSHostname": {
        "type": "string",
        "format": "hostname",
        "example": "rendezvous.example.com"
      },
      "IPv4Address": {
        "type": "string",
        "format": "ipv4",
        "example": "192.168.1.100"
      },
      "PortString": {
        "type": "string",
        "example": "8443"
      },
      "RVTO2AddrEntry": {
        "description": "A single owner server address entry. Each entry specifies the protocol,\nnetwork location (DNS hostname and/or IP address), and port for connecting\nto the owner server during TO2 protocol.\n\nBoth 'dns' and 'ip' fields are optional and may be provided independently\nor together. However, at least one addressing method MUST be specified\n(non-null) as required by FDO specification section 3.3.14. Requests that\nomit both 'dns' and 'ip' will be rejected with a 400 Bad Request error.\n\nWhen both 'dns' and 'ip' are provided, the device MUST attempt to connect\nusing the DNS address first. The device MUST only use the IP address after\nall DNS connection attempts have failed. This behavior is defined in the\nFDO specification section 3.3.14.\n",
        "type": "object",
        "properties": {
          "protocol": {
            "$ref": "#/components/schemas/TransportProtocol"
          },
          "dns": {
            "$ref": "#/components/schemas/DNSHostname"
          },
          "ip": {
            "$ref": "#/components/schemas/IPv4Address"
          },
          "port": {
            "$ref": "#/components/schemas/PortString"
          }
        },
        "required": [
          "protocol",
          "port"
        ]
      },
      "RVTO2Addr": {
        "description": "Rendezvous TO2 address configuration. Specifies one or more owner server\naddresses that devices should use to connect during the TO2 (Transfer of\nOwnership 2) protocol after completing rendezvous. Multiple entries provide\nfallback options if the primary address is unreachable.\n",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/RVTO2AddrEntry"
        }
      }
    },
    "responses": {
      "HealthStatus": {
        "description": "Server health status",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Health"
            },
            "examples": {
              "healthy": {
                "summary": "Example of a healthy server",
                "value": {
                  "version": "1.1.0",
                  "status": "OK",
                  "message": "the service is up and running"
                }
              }
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal Server Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "examples": {
              "serverError": {
                "summary": "Example of a server error",
                "value": {
                  "message": "An unexpected error occurred."
                }
              }
            }
          }
        }
      }
    }
  },
